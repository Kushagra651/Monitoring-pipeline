# .env.example
# Copy to .env and fill in all values before running docker compose.
#   cp .env.example .env
#
# Never commit .env to version control.

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=production                    # production | staging | development

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=mluser
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=ml_monitoring
POSTGRES_AIRFLOW_DB=airflow              # separate DB for Airflow metadata

# ── ML API ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=2                                # uvicorn worker count
ARTIFACTS_DIR=/app/artifacts

# ── Prometheus Exporter ───────────────────────────────────────────────────────
EXPORTER_PORT=9100
SCRAPE_INTERVAL_SEC=30
METRICS_NAMESPACE=ml_monitor

# ── Model / Training ──────────────────────────────────────────────────────────
TRAINING_DATA_SOURCE=db                  # db | csv | s3
TRAINING_SCHEDULE=0 2 * * 0             # cron: Sunday 02:00
MODEL_VERSION_TAG=                       # blank = auto timestamp
AUTO_PROMOTE=false                       # auto-promote model to production after training

# Minimum validation accuracy to gate model promotion
MIN_VAL_ACCURACY=0.80

# ── Drift detection ───────────────────────────────────────────────────────────
DRIFT_CHECK_SCHEDULE=0 */6 * * *        # every 6 hours
DRIFT_WINDOW_HOURS=6                    # hours of live logs to compare against reference
DRIFT_MIN_SAMPLES=30                    # minimum rows needed for drift check
KS_P_THRESHOLD=0.05                     # KS-test p-value threshold (numerical features)
CHI2_P_THRESHOLD=0.05                   # Chi-square p-value threshold (categorical)
PSI_WARNING=0.1                         # PSI ≥ this → warning severity
PSI_CRITICAL=0.2                        # PSI ≥ this → critical severity
PSI_BINS=10

# ── Quality checks ────────────────────────────────────────────────────────────
MISSING_WARN_PCT=0.05                   # 5%  missing → soft warning
MISSING_CRITICAL_PCT=0.15              # 15% missing → hard failure
OOR_CRITICAL_PCT=0.10                  # 10% out-of-range → hard failure
UNKNOWN_CAT_PCT=0.05                   # 5%  unknown categories → soft warning
CONFIDENCE_LOW_WARN=0.55               # mean confidence below this → soft warning

# ── Retrain trigger ───────────────────────────────────────────────────────────
RETRAIN_TRIGGER_SCHEDULE=15 */6 * * *  # 15 min after drift check
RETRAIN_COOLDOWN_HOURS=12              # minimum hours between auto-retrains
RETRAIN_AUTO_PROMOTE=false

# ── Alerting ──────────────────────────────────────────────────────────────────
ALERT_DEDUP_WINDOW_SEC=300             # suppress duplicate alerts for 5 min
ALERT_HTTP_TIMEOUT_SEC=10

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE/ME

# PagerDuty (Events API v2)
PAGERDUTY_ROUTING_KEY=change_me_pagerduty_key

# Generic webhook (optional)
ALERT_WEBHOOK_URL=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@yourcompany.com
SMTP_PASS=change_me_smtp_password
ALERT_EMAIL_FROM=ml-monitor@yourcompany.com
ALERT_EMAIL_TO=oncall@yourcompany.com,ml-team@yourcompany.com

# ── Airflow ───────────────────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=change_me_generate_with_fernet
AIRFLOW_SECRET_KEY=change_me_random_32_chars
AIRFLOW_ADMIN_PASSWORD=change_me_airflow_admin

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana

# ── Prediction logging ────────────────────────────────────────────────────────
LOG_BUFFER_SIZE=500                    # in-memory buffer before flush
LOG_FLUSH_INTERVAL_SEC=30             # background flush cadence
LOG_JSONL_PATH=/app/artifacts/logs    # JSONL fallback directory
